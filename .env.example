# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# RTDB_URL: Firebase Realtime Database URL for jam sessions.
RTDB_URL=https://your-project-id-default-rtdb.firebaseio.com

# GOOGLE_CLIENT_ID: OAuth 2.0 Web client ID for Google Sign-In.
# Replace with your own client ID from Firebase Console > Authentication > Sign-in method.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.MyApplication" parent="android:Theme.DeviceDefault.NoActionBar">
        <!-- Immediately enter immersive mode on launch to prevent status bar jump -->
        <item name="android:windowFullscreen">true</item>
        <!-- Ensure edge-to-edge drawing into notch areas immediately -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
